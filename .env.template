# =============================================================================
# MediSafe-MAS v3 Environment Configuration Template
# Copy this file to .env and fill in all required values
# =============================================================================

# ============= N8N Configuration =============
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=
GENERIC_TIMEZONE=Europe/Paris
N8N_RUNNERS_ENABLED=true

# Security Keys - GENERATE NEW VALUES (see SETUP_MEDISAFE_V3.md)
# PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
N8N_ENCRYPTION_KEY=REPLACE_WITH_GENERATED_KEY
N8N_USER_MANAGEMENT_JWT_SECRET=REPLACE_WITH_GENERATED_JWT

# ============= PostgreSQL Configuration =============
POSTGRES_USER=medisafe_admin
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
POSTGRES_DB=medisafe_db

# ============= Ollama Configuration =============
OLLAMA_HOST=ollama:11434
