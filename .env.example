# =============================================================================
# Modèle de variables d'environnement — instance n8n (WiseAI)
# Usage : recopier sous le nom .env et compléter les valeurs opérationnelles.
# Le fichier .env est exclu du contrôle de version (.gitignore).
# Procédure détaillée : DEPLOY.md
# =============================================================================

# Port TCP publié sur l'hôte (URL navigateur : http://localhost:<N8N_PORT>/)
N8N_PORT=5678

# Nom d'hôte ou adresse telle que présentée par l'instance (localhost en atelier)
N8N_HOST=localhost

# Schéma d'accès HTTP ou HTTPS selon la terminaison TLS éventuelle
N8N_PROTOCOL=http

# URL publique de base pour la résolution des webhooks (tunnel, proxy, FQDN)
# Exemple : WEBHOOK_URL=https://votre-sous-domaine.example.com/
WEBHOOK_URL=

# Fuseau horaire IANA (planifications et horodatage des exécutions)
GENERIC_TIMEZONE=Europe/Paris

# Clé symétrique pour le chiffrement des identifiants stockés en base.
# Recommandation : entropie élevée (ex. 32 octets aléatoires encodés Base64).
# Référence : DEPLOY.md (phase 1).
# PowerShell (illustration) :
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
N8N_ENCRYPTION_KEY=

# Activation des runners d'exécution n8n (comportement par défaut sur versions récentes)
N8N_RUNNERS_ENABLED=true
