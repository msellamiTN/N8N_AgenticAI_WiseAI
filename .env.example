# =============================================================================
# MediSafe-MAS v3 Environment Configuration Template
# =============================================================================
# Usage: Copy this file to .env and configure with your values
#   cp .env.example .env
#
# The .env file is excluded from version control (.gitignore)
# Generate secure keys before production deployment!
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL Database Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Database credentials for N8N and audit logging
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=change_me_secure_password_here
POSTGRES_DB=n8n

# ──────────────────────────────────────────────────────────────────────────────
# N8N Core Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Port for N8N web interface (default: 5678)
N8N_PORT=5678

# Hostname for N8N instance (use 'localhost' for local dev, domain for production)
N8N_HOST=localhost

# Protocol (http for local dev, https for production with SSL/TLS)
N8N_PROTOCOL=http

# Public webhook URL (leave empty for local dev, set to public URL for production)
# Example: https://n8n.yourdomain.com/
WEBHOOK_URL=http://localhost:5678/

# Timezone for workflow scheduling and timestamps (IANA format)
# Examples: Europe/Paris, America/New_York, Asia/Tokyo, UTC
GENERIC_TIMEZONE=Europe/Paris

# ──────────────────────────────────────────────────────────────────────────────
# N8N Security Keys (CRITICAL - MUST CHANGE FOR PRODUCTION)
# ──────────────────────────────────────────────────────────────────────────────
# Generate secure random keys using one of these methods:
#
# Linux/macOS:
#   openssl rand -base64 32
#
# Windows PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
#
# Online (use with caution):
#   https://www.random.org/strings/?num=1&len=32&digits=on&upperalpha=on&loweralpha=on&unique=on&format=plain

# Encryption key for credentials stored in database (32+ bytes recommended)
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_32_BYTE_KEY

# JWT secret for user session management (32+ bytes recommended)
N8N_USER_MANAGEMENT_JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_32_BYTE_KEY

# ──────────────────────────────────────────────────────────────────────────────
# N8N Runtime Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Enable workflow runners (required for agent workflows)
N8N_RUNNERS_ENABLED=true

# Disable telemetry and diagnostics for privacy
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false

# Secure cookie setting (false for local dev, true for production HTTPS)
N8N_SECURE_COOKIE=false

# ──────────────────────────────────────────────────────────────────────────────
# Ollama Configuration (Local LLM Inference)
# ──────────────────────────────────────────────────────────────────────────────
# Ollama service hostname and port (Docker internal network)
OLLAMA_HOST=ollama:11434

# ──────────────────────────────────────────────────────────────────────────────
# Qdrant Configuration (Vector Database for RAG)
# ──────────────────────────────────────────────────────────────────────────────
# Qdrant service hostname (Docker internal network)
QDRANT_HOST=qdrant

# Qdrant HTTP API port
QDRANT_PORT=6333

# Full Qdrant URL for N8N nodes
QDRANT_URL=http://qdrant:6333

# ──────────────────────────────────────────────────────────────────────────────
# Docker Compose Profile Selection
# ──────────────────────────────────────────────────────────────────────────────
# Choose hardware acceleration profile:
#   - cpu         : CPU-only (works on all systems, slower inference)
#   - gpu-nvidia  : NVIDIA GPU acceleration (requires NVIDIA Docker runtime)
#   - gpu-amd     : AMD GPU acceleration (requires ROCm support)
COMPOSE_PROFILES=cpu

# ──────────────────────────────────────────────────────────────────────────────
# Optional: Production Settings
# ──────────────────────────────────────────────────────────────────────────────
# Uncomment and configure for production deployments

# N8N Basic Auth (simple authentication)
# N8N_BASIC_AUTH_ACTIVE=true
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=change_me_secure_password

# N8N User Management (advanced authentication)
# N8N_USER_MANAGEMENT_DISABLED=false

# External PostgreSQL (if not using Docker PostgreSQL)
# DB_POSTGRESDB_HOST=your-postgres-host.example.com
# DB_POSTGRESDB_PORT=5432

# Reverse Proxy Settings (if behind nginx/traefik)
# N8N_PATH=/
# N8N_LISTEN_ADDRESS=0.0.0.0

# Execution Limits
# EXECUTIONS_TIMEOUT=3600
# EXECUTIONS_TIMEOUT_MAX=7200

# ──────────────────────────────────────────────────────────────────────────────
# Optional: Resource Limits
# ──────────────────────────────────────────────────────────────────────────────
# Uncomment to set memory/CPU limits for containers

# Ollama Memory Limit (adjust based on available RAM)
# OLLAMA_MAX_MEMORY=8g

# N8N Memory Limit
# N8N_MAX_MEMORY=2g

# PostgreSQL Memory Limit
# POSTGRES_MAX_MEMORY=1g

# Qdrant Memory Limit
# QDRANT_MAX_MEMORY=2g

# ──────────────────────────────────────────────────────────────────────────────
# Optional: Logging Configuration
# ──────────────────────────────────────────────────────────────────────────────
# N8N_LOG_LEVEL=info
# N8N_LOG_OUTPUT=console

# ──────────────────────────────────────────────────────────────────────────────
# End of Configuration
# ──────────────────────────────────────────────────────────────────────────────
